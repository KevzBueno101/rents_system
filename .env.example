# Database Configuration
DB_NAME=rents_db
DB_USER=root
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=3306

# Django Configuration
SECRET_KEY=your_secret_key_here
DEBUG=True

# Email Configuration for Password Reset
# Production: SendGrid (Primary) - Development: Gmail (Fallback)
SENDGRID_API_KEY=your_sendgrid_api_key_here
FROM_EMAIL=your_verified_email@domain.com

# Gmail SMTP (Development/Fallback)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
DEFAULT_FROM_EMAIL=RENTS System <your_email@gmail.com>

# Priority: SendGrid API Key > Gmail SMTP > Console
# Render will use SendGrid automatically when SENDGRID_API_KEY is set
# Local development will use Gmail SMTP when EMAIL_HOST_USER is set
