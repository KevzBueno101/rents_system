{% extends 'base_dashboard.html' %}
{% load avatar_tags %}

{% block title %}Rooms{% endblock %}
{% block page_title %}Rooms{% endblock %}

{% block content %}

<!-- ADD ROOM MODAL -->
<div class="modal fade" id="addRoomModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-door-open"></i> Add Room
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                {% if add_error %}
                <div class="alert alert-danger py-2 text-center">{{ add_error }}</div>
                {% endif %}

                <form method="POST" action="{% url 'add_room' %}" enctype="multipart/form-data">
                    {% csrf_token %}

                    <!-- FLOOR + ID -->
                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-building"></i></span>
                                <input type="number" name="floor" class="form-control" placeholder="Floor (e.g. 1, 2)" min="1" required>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-door-open"></i></span>
                                <input type="text" name="room_number" class="form-control" placeholder="ID (e.g. A, B, 1)" required>
                            </div>
                        </div>
                    </div>

                    <!-- CAPACITY + RATE -->
                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-people"></i></span>
                                <input type="number" name="capacity" class="form-control" placeholder="Capacity (beds)" min="1" required>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="input-group">
                                <span class="input-group-text">₱</span>
                                <input type="number" name="monthly_rate" class="form-control" placeholder="Monthly Rate" min="0" step="0.01" required>
                            </div>
                        </div>
                    </div>

                    <!-- AREA + CR -->
                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-rulers"></i></span>
                                <input type="number" name="area" class="form-control" placeholder="Area (sqm)" step="0.01" min="0">
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-droplet"></i></span>
                                <input type="number" name="num_cr" class="form-control" placeholder="No. of CR" min="1" value="1">
                            </div>
                        </div>
                    </div>

                    <!-- BED TYPE -->
                    <div class="mb-2">
                        <select name="bed_type" class="form-select">
                            <option value="single">Single Bed</option>
                            <option value="double_deck">Double Deck</option>
                            <option value="both">Both</option>
                        </select>
                    </div>

                    <!-- INCLUSIONS -->
                    <div class="mb-2">
                        <label class="form-label text-muted mb-1" style="font-size:12px;">
                            <i class="bi bi-check2-square"></i> Inclusions
                        </label>
                        <div class="row g-1">
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="has_sink" id="addSink">
                                    <label class="form-check-label" style="font-size:13px;" for="addSink">Sink</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="water_included" id="addWater">
                                    <label class="form-check-label" style="font-size:13px;" for="addWater">Water</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="electricity_included" id="addElec">
                                    <label class="form-check-label" style="font-size:13px;" for="addElec">Electricity</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="has_wifi" id="addWifi">
                                    <label class="form-check-label" style="font-size:13px;" for="addWifi">WiFi</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- APPLIANCES -->
                    <div class="mb-2">
                        <label class="form-label text-muted mb-1" style="font-size:12px;">
                            <i class="bi bi-plug"></i> Appliances
                        </label>
                        <div class="row g-1">
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="has_fan" id="addFan">
                                    <label class="form-check-label" style="font-size:13px;" for="addFan">Fan</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="has_aircon" id="addAircon">
                                    <label class="form-check-label" style="font-size:13px;" for="addAircon">Aircon</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="has_ref" id="addRef">
                                    <label class="form-check-label" style="font-size:13px;" for="addRef">Refrigerator</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="has_tv" id="addTv">
                                    <label class="form-check-label" style="font-size:13px;" for="addTv">TV</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- PHOTO -->
                    <div class="mb-2">
                        <label class="form-label text-muted" style="font-size:13px;">
                            <i class="bi bi-camera"></i> Room Photo (optional)
                        </label>
                        <input type="file" name="photo" class="form-control" accept="image/*">
                    </div>

                    <!-- NAMING HINT -->
                    <div class="p-2 rounded mb-3" style="background:#f8f9fa; border-left:3px solid #aaa;">
                        <p class="mb-1" style="font-size:11px; font-weight:600; color:#555;">
                            <i class="bi bi-lightbulb"></i> Naming Convention
                        </p>
                        <p class="mb-1" style="font-size:11px; color:#888;">
                            Format: <strong>Room [Floor]-[ID]</strong>
                        </p>
                        <div style="font-size:11px; color:#888;">
                            e.g.
                            <span class="badge bg-light text-dark border mx-1">Room 1-A</span>
                            <span class="badge bg-light text-dark border mx-1">Room 1-B</span>
                            <span class="badge bg-light text-dark border mx-1">Room 2-A</span>
                        </div>
                    </div>

                    <button class="btn btn-dark w-100">
                        <i class="bi bi-plus-circle"></i> Add Room
                    </button>

                </form>
            </div>
        </div>
    </div>
</div>

<!-- EDIT ROOM MODAL -->
<div class="modal fade" id="editRoomModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-pencil"></i> Edit Room
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form method="POST" action="" id="editRoomForm" enctype="multipart/form-data">
                    {% csrf_token %}

                    <!-- FLOOR + ID -->
                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-building"></i></span>
                                <input type="number" name="floor" id="editFloor" class="form-control" placeholder="Floor" min="1" required>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-door-open"></i></span>
                                <input type="text" name="room_number" id="editRoomNumber" class="form-control" placeholder="ID" required>
                            </div>
                        </div>
                    </div>

                    <!-- CAPACITY + RATE -->
                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-people"></i></span>
                                <input type="number" name="capacity" id="editCapacity" class="form-control" placeholder="Capacity" min="1" required>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="input-group">
                                <span class="input-group-text">₱</span>
                                <input type="number" name="monthly_rate" id="editMonthlyRate" class="form-control" placeholder="Monthly Rate" min="0" step="0.01" required>
                            </div>
                        </div>
                    </div>

                    <!-- AREA + CR -->
                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-rulers"></i></span>
                                <input type="number" name="area" id="editArea" class="form-control" placeholder="Area (sqm)" step="0.01" min="0">
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-droplet"></i></span>
                                <input type="number" name="num_cr" id="editNumCR" class="form-control" placeholder="No. of CR" min="1">
                            </div>
                        </div>
                    </div>

                    <!-- BED TYPE -->
                    <div class="mb-2">
                        <select name="bed_type" id="editBedType" class="form-select">
                            <option value="single">Single Bed</option>
                            <option value="double_deck">Double Deck</option>
                            <option value="both">Both</option>
                        </select>
                    </div>

                    <!-- INCLUSIONS -->
                    <div class="mb-2">
                        <label class="form-label text-muted mb-1" style="font-size:12px;">
                            <i class="bi bi-check2-square"></i> Inclusions
                        </label>
                        <div class="row g-1">
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="has_sink" id="editSink">
                                    <label class="form-check-label" style="font-size:13px;" for="editSink">Sink</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="water_included" id="editWater">
                                    <label class="form-check-label" style="font-size:13px;" for="editWater">Water</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="electricity_included" id="editElec">
                                    <label class="form-check-label" style="font-size:13px;" for="editElec">Electricity</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="has_wifi" id="editWifi">
                                    <label class="form-check-label" style="font-size:13px;" for="editWifi">WiFi</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- APPLIANCES -->
                    <div class="mb-2">
                        <label class="form-label text-muted mb-1" style="font-size:12px;">
                            <i class="bi bi-plug"></i> Appliances
                        </label>
                        <div class="row g-1">
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="has_fan" id="editFan">
                                    <label class="form-check-label" style="font-size:13px;" for="editFan">Fan</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="has_aircon" id="editAircon">
                                    <label class="form-check-label" style="font-size:13px;" for="editAircon">Aircon</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="has_ref" id="editRef">
                                    <label class="form-check-label" style="font-size:13px;" for="editRef">Refrigerator</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="has_tv" id="editTv">
                                    <label class="form-check-label" style="font-size:13px;" for="editTv">TV</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- PHOTO -->
                    <div class="mb-3">
                        <label class="form-label text-muted" style="font-size:13px;">
                            <i class="bi bi-camera"></i> Room Photo (optional — leave blank to keep current)
                        </label>
                        <input type="file" name="photo" class="form-control" accept="image/*">
                    </div>

                    <button class="btn btn-dark w-100">
                        <i class="bi bi-check-circle"></i> Save Changes
                    </button>

                </form>
            </div>
        </div>
    </div>
</div>

<!-- ROOM INFO MODAL -->
<div class="modal fade" id="roomInfoModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-info-circle"></i>
                    <span id="infoRoomCode"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">

                <div id="infoRoomPhoto"></div>

                <div class="p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted">Status</span>
                        <span id="infoStatus" class="badge"></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="bi bi-building"></i> Floor</span>
                        <span id="infoFloor"></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="bi bi-people"></i> Occupancy</span>
                        <span id="infoOccupancy"></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="bi bi-cash"></i> Monthly Rate</span>
                        <span id="infoRate" class="fw-bold"></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="bi bi-rulers"></i> Area</span>
                        <span id="infoArea"></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="bi bi-droplet"></i> CR</span>
                        <span id="infoCR"></span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted"><i class="bi bi-moon"></i> Bed Type</span>
                        <span id="infoBedType"></span>
                    </div>

                    <hr>

                    <p class="text-muted mb-2" style="font-size:13px;">
                        <i class="bi bi-check2-square"></i> Inclusions & Appliances:
                    </p>
                    <div id="infoInclusions" class="mb-3"></div>

                    <hr>

                    <p class="text-muted mb-2" style="font-size:13px;">
                        <i class="bi bi-person"></i> Tenants in this room:
                    </p>
                    <div id="infoTenants"></div>

                </div>

<!-- HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-0">All Rooms</h5>
        <small class="text-muted">{{ rooms.count }} room{{ rooms.count|pluralize }} total</small>
    </div>
    <div class="d-flex gap-2">
        <!-- Sort Controls -->
        <div class="dropdown">
            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-sort-down"></i> Sort by
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="?sort=floor&order=asc">
                    <i class="bi bi-building"></i> Floor
                    {% if current_sort == 'floor' and current_order == 'asc' %}<i class="bi bi-check text-success"></i>{% endif %}
                </a></li>
                <li><a class="dropdown-item" href="?sort=rate&order=asc">
                    <i class="bi bi-cash"></i> Rate (Low to High)
                    {% if current_sort == 'rate' and current_order == 'asc' %}<i class="bi bi-check text-success"></i>{% endif %}
                </a></li>
                <li><a class="dropdown-item" href="?sort=rate&order=desc">
                    <i class="bi bi-cash"></i> Rate (High to Low)
                    {% if current_sort == 'rate' and current_order == 'desc' %}<i class="bi bi-check text-success"></i>{% endif %}
                </a></li>
                <li><a class="dropdown-item" href="?sort=capacity&order=asc">
                    <i class="bi bi-people"></i> Capacity (Low to High)
                    {% if current_sort == 'capacity' and current_order == 'asc' %}<i class="bi bi-check text-success"></i>{% endif %}
                </a></li>
                <li><a class="dropdown-item" href="?sort=capacity&order=desc">
                    <i class="bi bi-people"></i> Capacity (High to Low)
                    {% if current_sort == 'capacity' and current_order == 'desc' %}<i class="bi bi-check text-success"></i>{% endif %}
                </a></li>
                <li><a class="dropdown-item" href="?sort=room_number&order=asc">
                    <i class="bi bi-door-open"></i> Room Number
                    {% if current_sort == 'room_number' %}<i class="bi bi-check text-success"></i>{% endif %}
                </a></li>
            </ul>
        </div>
        <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#addRoomModal">
            <i class="bi bi-plus-circle"></i>
            <span class="d-none d-md-inline">Add Room</span>
        </button>
    </div>
</div>

<!-- ROOM CARDS -->
{% if rooms %}
<div class="row g-3">
    {% for room in rooms %}
    <div class="col-sm-6 col-lg-4 col-xl-3">
        <div class="card border-0 shadow-sm h-100">

            {% if room.photo %}
                <img src="{{ room.photo.url }}"
                     alt="{{ room.room_code }}"
                     style="width:100%; height:160px; object-fit:cover; border-radius:12px 12px 0 0;">
            {% else %}
                <div style="width:100%; height:160px; background:#f4f6f9; border-radius:12px 12px 0 0; display:flex; align-items:center; justify-content:center;">
                    <i class="bi bi-door-open" style="font-size:48px; color:#ccc;"></i>
                </div>
            {% endif %}

            <div style="position:relative;">
                <span class="badge position-absolute"
                    style="top:-14px; right:12px;
                           background:{% if room.is_full %}#e53935{% else %}#1db954{% endif %};">
                    {% if room.is_full %}
                        {{ room.status }}
                    {% else %}
                        Vacant ({{ room.available_beds }})
                    {% endif %}
                </span>
            </div>

            <div class="card-body pt-3">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold mb-0">{{ room.room_code }}</h6>
                    <button class="btn btn-sm btn-link p-0 text-muted info-room-btn"
                        data-id="{{ room.id }}"
                        data-code="{{ room.room_code }}"
                        data-floor="{{ room.floor }}"
                        data-occupied="{{ room.occupied_beds }}"
                        data-capacity="{{ room.capacity }}"
                        data-rate="{{ room.monthly_rate }}"
                        data-status="{{ room.status }}"
                        data-photo="{% if room.photo %}{{ room.photo.url }}{% endif %}"
                        data-tenants="{% for t in room.get_tenants %}{{ t.full_name }}{% if not forloop.last %}|{% endif %}{% endfor %}"
                        data-area="{{ room.area|default:'' }}"
                        data-cr="{{ room.num_cr }}"
                        data-bedtype="{{ room.get_bed_type_display }}"
                        data-sink="{{ room.has_lababo }}"
                        data-water="{{ room.water_included }}"
                        data-elec="{{ room.electricity_included }}"
                        data-fan="{{ room.has_fan }}"
                        data-aircon="{{ room.has_aircon }}"
                        data-ref="{{ room.has_ref }}"
                        data-tv="{{ room.has_tv }}"
                        data-wifi="{{ room.has_wifi }}">
                        <i class="bi bi-info-circle fs-5"></i>
                    </button>
                </div>

                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted" style="font-size:13px;">
                        <i class="bi bi-people"></i> Occupancy
                    </span>
                    <span style="font-size:13px; font-weight:600;">
                        {{ room.occupied_beds }} / {{ room.capacity }}
                    </span>
                </div>

                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted" style="font-size:13px;">
                        <i class="bi bi-cash"></i> Monthly Rate
                    </span>
                    <span style="font-size:13px; font-weight:600;">
                        ₱{{ room.monthly_rate }}
                    </span>
                </div>

                <div class="progress mb-3" style="height:6px;">
                    {% if room.capacity > 0 %}
                    <div class="progress-bar"
                        style="width:{% widthratio room.occupied_beds room.capacity 100 %}%;
                               background:{% if room.is_full %}#e53935{% else %}#1db954{% endif %};">
                    </div>
                    {% endif %}
                </div>

                <div style="font-size:12px; color:#888;">
                    <i class="bi bi-person"></i>
                    {% for tenant in room.get_tenants %}
                        {{ tenant.full_name }}{% if not forloop.last %}, {% endif %}
                    {% empty %}
                        No tenants yet
                    {% endfor %}
                </div>

            </div>

            <div class="card-footer bg-white border-0 pt-0 pb-3 px-3">
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-primary w-100 edit-room-btn"
                        data-id="{{ room.id }}"
                        data-room="{{ room.room_number }}"
                        data-floor="{{ room.floor }}"
                        data-capacity="{{ room.capacity }}"
                        data-rate="{{ room.monthly_rate }}"
                        data-area="{{ room.area|default:'' }}"
                        data-cr="{{ room.num_cr }}"
                        data-bedtype="{{ room.bed_type }}"
                        data-sink="{{ room.has_lababo }}"
                        data-water="{{ room.water_included }}"
                        data-elec="{{ room.electricity_included }}"
                        data-fan="{{ room.has_fan }}"
                        data-aircon="{{ room.has_aircon }}"
                        data-ref="{{ room.has_ref }}"
                        data-tv="{{ room.has_tv }}"
                        data-wifi="{{ room.has_wifi }}">
                        <i class="bi bi-pencil"></i> Edit
                    </button>
                    <form method="POST" action="{% url 'delete_room' room.id %}"
                        onsubmit="return confirm('Delete {{ room.room_code }}? This cannot be undone!')">
                        {% csrf_token %}
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
    {% endfor %}
</div>

{% else %}
<div class="text-center py-5">
    <i class="bi bi-door-open" style="font-size:48px; color:#ddd;"></i>
    <p class="text-muted mt-3">No rooms yet. Add your first room!</p>
    <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#addRoomModal">
        <i class="bi bi-plus-circle"></i> Add Room
    </button>
</div>
{% endif %}

{% if show_add_modal %}
<script>
    document.addEventListener('DOMContentLoaded', function() {
